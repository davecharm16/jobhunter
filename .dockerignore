# Build context hygiene — keep secrets, local state, and heavy dirs out of the image.
.git
.venv
**/__pycache__
**/*.pyc
.pytest_cache
.mypy_cache
.ruff_cache

# Node deps + prebuilt frontend (the image rebuilds dist/ in a clean stage).
node_modules
src/jobhunter/web/frontend/node_modules
src/jobhunter/web/frontend/dist
src/jobhunter/web/frontend/tsconfig.tsbuildinfo

# Local runtime state + secrets (never bake these).
.env
.env.*
!.env.example
out/
.cost-ledger.json

# Repo cruft not needed at runtime.
_bmad
_bmad-output
.agent
.agents
.claude
.codex
.sixth
.worktrees
.DS_Store
*.pdf
*.bak
