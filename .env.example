LLM_API_KEY=replace-with-your-provider-key
MONTHLY_SPEND_CAP_USD=25.00
# Optional: override the per-call LLM timeout (default 60.0 seconds)
# LLM_CALL_TIMEOUT_SECONDS=60
# Shared-token auth for POST /api/paste from non-loopback callers (e.g. n8n).
# Loopback browser requests (127.0.0.1) skip this check per DECISIONS.md §6.
# Leave empty if only the browser uses the endpoint.
INGEST_TOKEN=
# Story 6.1: optional Google Chat incoming webhook URL. When set, the pipeline
# POSTs a single notification per package that clears all three drift checks
# (fabrication, content-loss, keyword-stuffing). Leave empty to disable.
GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/...
# Supabase Postgres connection for the application tracker.
# Local dev (supabase start): postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Hosted: copy the "Connection string" (URI, session pooler) from your Supabase project settings.
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Job Scan: n8n webhook the dashboard "Run scan now" button pings to trigger an
# external scan run. Leave empty to disable manual triggering (the button then
# returns "scan engine not configured"). This is the trigger URL of your n8n
# scan workflow (F2) once it exists.
N8N_SCAN_TRIGGER_URL=
# Screenshot → JD: n8n webhook that runs Claude Code vision on an uploaded
# screenshot and returns the extracted job description (for the paste panel's
# "Upload screenshot" button). Leave empty to disable that button's backend.
N8N_IMAGE_VISION_URL=
